# Server
PORT=5001
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=smart_answer_evaluation

# Auth
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=1d

# Default admin (created on db init)
ADMIN_NAME=Administrator
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# Local answer matching (no paid APIs — runs fully offline)
AI_PASS_THRESHOLD=80

# OCR (auto-runs on scanned PDFs via Tesseract.js)
PDF_MIN_TEXT_LENGTH=30
OCR_RENDER_SCALE=3
